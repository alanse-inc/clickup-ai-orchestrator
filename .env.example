# ClickUp
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# GitHub Auth (PAT or App - mutually exclusive)
GITHUB_PAT=

# GitHub App Auth (alternative to PAT)
# GITHUB_APP_ID=
# GITHUB_APP_INSTALLATION_ID=
# GITHUB_APP_PRIVATE_KEY=

# GitHub Repository (target repository for Claude Code)
GITHUB_OWNER=
GITHUB_REPO=

# Optional
# GITHUB_WORKFLOW_FILE=agent.yml
# POLL_INTERVAL_MS=10000

# ClickUp Status Mapping (optional, defaults shown)
# CLICKUP_STATUS_READY_FOR_SPEC=ready for spec
# CLICKUP_STATUS_GENERATING_SPEC=generating spec
# CLICKUP_STATUS_SPEC_REVIEW=spec review
# CLICKUP_STATUS_READY_FOR_CODE=ready for code
# CLICKUP_STATUS_IMPLEMENTING=implementing
# CLICKUP_STATUS_PR_REVIEW=pr review
# CLICKUP_STATUS_CLOSED=closed
